#===============================================================================
# 合歡山松雪樓 訂房預填設定檔
# 複製此檔案為 .env，填入你的個人資料後供 prefill 腳本使用
#
# cp .env.example .env
# vim .env          # 填入資料
# ./scripts/prefill_booking.py 2026-07-01
#===============================================================================

# --- 訂購人姓名 ---
LAST_NAME=王
FIRST_NAME=小明

# --- 性別 (0=男, 1=女) ---
SEX=0

# --- 生日 (西元年, 月, 日) ---
BIRTH_YEAR=1990
BIRTH_MONTH=01
BIRTH_DAY=01

# --- 證件 (0=身分證字號, 1=護照號碼) ---
ID_TYPE=0
ID_NUMBER=A123456789

# --- 國籍 (TW=台灣) ---
COUNTRY=TW

# --- 聯絡方式 ---
EMAIL=example@mail.com
PHONE=0912345678
ADDRESS=台北市大安區...

# --- 訂單查詢密碼 (10 位數內英文或數字) ---
PASSWORD=mypassword

# --- 預設入住時間 (15:00/15:30/16:00/16:30/17:00) ---
CHECKIN_TIME=15:00

# --- 付款方式 (0=線上信用卡, 1=LINE Pay) ---
PAYMENT=0

# --- 發票 (3=不開立統編, 2=要開立統編) ---
INVOICE=3

# --- 收據 (5=代收轉付電子收據) ---
RECEIPT=5

# --- 備註 (選填) ---
NOTE=

# --- 國民旅遊卡 (true/false) ---
NATIONAL_CARD=false

#===============================================================================
# Telegram Bot 設定（選擇性）
# 啟用後儀表板會自動掛載 POST /bot/telegram 並在啟動時設定 webhook
#===============================================================================

# Telegram Bot Token（向 @BotFather 申請）
TELEGRAM_TOKEN=

# 部署後的公開網址（用於 webhook 註冊，例如 https://你的專案.onrender.com）
PUBLIC_URL=
